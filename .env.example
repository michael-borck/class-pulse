# Copy this file to .env and fill in real values:  cp .env.example .env
# The application loads .env automatically (via python-dotenv).

# Application Settings
FLASK_APP=wsgi.py
# Leave as 'production'. Set to 'development' ONLY for local debugging — it
# enables the Werkzeug debugger, which allows remote code execution if exposed.
FLASK_ENV=production
DEBUG=False
PORT=5002

# Security Settings
# REQUIRED. Signs session cookies — a known/shared key lets anyone forge an
# admin session. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Set to true when serving over HTTPS so cookies are never sent over plain
# HTTP (also enables the HSTS header).
SESSION_COOKIE_SECURE=False

# How long a presenter login lasts, in seconds (default 24 h).
PERMANENT_SESSION_LIFETIME=86400

# Behind a reverse proxy (Caddy/nginx)? Set to the number of proxy hops
# (usually 1) so X-Forwarded-For/-Proto are trusted: rate limits then key on
# the real client IP and generated join URLs/QR codes use https. Leave 0 when
# the app is exposed directly.
TRUST_PROXY=0

# Maximum request body size in bytes (default 256 KB). Bigger requests get 413.
# MAX_CONTENT_LENGTH=262144

# Override the default Content-Security-Policy header; set empty to disable.
# CONTENT_SECURITY_POLICY=

# AI Question Generation (global — one provider for the whole deployment).
# Two adapter families: "openai" (OpenAI-compatible /chat/completions — also
# Ollama's /v1, Groq, Together, OpenRouter, ...) and "anthropic" (native
# api.anthropic.com /messages). Both AI_BASE_URL values are the "/v1" root.
# Examples:
#   OpenAI:    AI_PROVIDER=openai    AI_BASE_URL=https://api.openai.com/v1      AI_MODEL=gpt-4o-mini
#   Ollama:    AI_PROVIDER=openai    AI_BASE_URL=http://localhost:11434/v1      AI_MODEL=llama3.2  (AI_API_KEY blank)
#   Anthropic: AI_PROVIDER=anthropic AI_BASE_URL=https://api.anthropic.com/v1   AI_MODEL=claude-haiku-4-5
# Leave AI_PROVIDER blank to disable AI generation entirely.
AI_PROVIDER=
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
# AI_ENABLED is auto-detected (on when a provider is fully configured); set it
# explicitly only to force-disable a configured provider.
# AI_ENABLED=true

# Database Settings
# Default: sqlite named classpulse_flask.db in the instance/ directory.
# (Relative sqlite paths resolve against instance/ — don't prefix "instance/".)
# DATABASE_URL=sqlite:///classpulse_flask.db
# For PostgreSQL (recommended for larger deployments):
# DATABASE_URL=postgresql://username:password@localhost/classpulse

# Admin: there is no default admin account. The first person to register on a
# fresh deployment becomes the verified admin automatically. Nothing to set here.

# Email (registration verification + password reset)
# New registrations must confirm their email with a code before they can log in,
# and forgotten passwords are recovered the same way. Choose a provider below.
#
# EMAIL_PROVIDER options:
#   dev    (default) — logs the code instead of sending. Codes appear in the app
#                      log / `docker compose logs`. Fine for local dev; NOT for
#                      real users, who never receive an email.
#   resend — Resend API (https://resend.com). Set RESEND_API_KEY.
#   smtp   — any SMTP server. Set SMTP_SERVER/SMTP_PORT and, if needed,
#            SMTP_USER/SMTP_PASSWORD and SMTP_USE_TLS (default true) / SMTP_USE_SSL.
#   gmail  — Gmail via an app password. Set GMAIL_APP_PASSWORD and MAIL_FROM to
#            the Gmail address.
EMAIL_PROVIDER=dev
# The From: address and display name on outgoing mail.
MAIL_FROM=no-reply@classpulse.local
MAIL_FROM_NAME=ClassPulse
# Provider credentials (only the ones for your chosen EMAIL_PROVIDER matter).
# RESEND_API_KEY=
# SMTP_SERVER=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# GMAIL_APP_PASSWORD=
# How long an emailed verification/reset code stays valid, in minutes.
EMAIL_CODE_TTL_MIN=30
# Optional: restrict registration to these email domains (comma-separated).
# Leave blank for open registration. Example: curtin.edu.au,student.curtin.edu.au
ALLOWED_DOMAINS=

# Rate Limiting
# Login/register/join/respond and the AI endpoint are rate-limited. The default
# in-memory store suits the single-process deployment; if you scale out, use a
# shared store, e.g. redis://localhost:6379
# RATELIMIT_STORAGE_URI=redis://localhost:6379

# WebSocket Settings
# Async mode for Flask-SocketIO. 'threading' matches the gthread gunicorn
# worker used by the provided Dockerfile/start.sh; leave unset to auto-detect.
SOCKETIO_ASYNC_MODE=threading
# Required ONLY when running more than one gunicorn worker: a shared message
# queue so Socket.IO broadcasts reach clients on other workers.
# SOCKETIO_MESSAGE_QUEUE=redis://localhost:6379/0
