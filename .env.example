# Copy this file to .env and fill in real values:  cp .env.example .env
# The application loads .env automatically (via python-dotenv).

# Application Settings
FLASK_APP=wsgi.py
# Leave as 'production'. Set to 'development' ONLY for local debugging — it
# enables the Werkzeug debugger, which allows remote code execution if exposed.
FLASK_ENV=production
DEBUG=False
PORT=5002

# Security Settings
# REQUIRED. Signs session cookies — a known/shared key lets anyone forge an
# admin session. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Database Settings
DATABASE_URL=sqlite:///instance/classpulse_flask.db
# For PostgreSQL (recommended for larger deployments):
# DATABASE_URL=postgresql://username:password@localhost/classpulse

# Admin Settings
# Username for the bootstrap admin created on first run.
DEFAULT_ADMIN_USER=admin
# Leave BLANK to have a strong random password generated and printed once on
# first run (recommended). Set a value only if you want to choose it yourself.
DEFAULT_ADMIN_PASS=

# Session Settings
SESSION_COOKIE_SECURE=False  # Set to True when served over HTTPS
SESSION_COOKIE_HTTPONLY=True
PERMANENT_SESSION_LIFETIME=86400  # 24 hours in seconds

# WebSocket Settings
SOCKETIO_ASYNC_MODE=eventlet  # Use 'eventlet' or 'gevent' for production
